---
interface Props {
  title: string;
  description: string;
  href?: string;
  imageAlt?: string;
}

const {
  title,
  description,
  href = '#',
  imageAlt = '[PLACEHOLDER] Project preview image',
} = Astro.props;
---

<article class="group flex flex-col border-2 border-black bg-white transition-colors hover:border-accent">
  <div class="aspect-[16/10] overflow-hidden bg-black/5">
    <img
      src="/images/project-placeholder.svg"
      alt={imageAlt}
      width="640"
      height="400"
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </div>
  <div class="flex flex-1 flex-col p-6 md:p-8">
    <h3 class="mb-3 font-heading text-xl uppercase tracking-wide text-black group-hover:text-accent md:text-2xl">
      {title}
    </h3>
    <p class="mb-6 flex-1 text-base leading-relaxed text-black/70">
      {description}
    </p>
    <a
      href={href}
      class="inline-flex items-center gap-2 font-heading text-sm uppercase tracking-widest text-accent transition-colors hover:text-black"
    >
      Learn more
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>
