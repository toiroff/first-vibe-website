---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/projects', label: 'Projects' },
];

function isActive(href: string, path: string): boolean {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="border-b border-black/10">
  <div class="content-container flex flex-wrap items-center justify-between gap-4 px-6 py-5 md:px-8">
    <a
      href="/"
      class="font-heading text-lg uppercase tracking-widest text-black transition-colors hover:text-accent sm:text-xl"
      aria-label="Pete McPherson — Home"
    >
      Pete McPherson
    </a>

    <nav aria-label="Main navigation">
      <ul class="flex items-center gap-4 sm:gap-6 md:gap-10">
        {
          navLinks.map(({ href, label }) => {
            const active = isActive(href, currentPath);
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'font-heading text-sm uppercase tracking-widest transition-colors',
                    active
                      ? 'text-accent underline decoration-2 underline-offset-4'
                      : 'text-black hover:text-accent',
                  ]}
                  aria-current={active ? 'page' : undefined}
                >
                  {label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
  </div>
</header>
