---
import BaseLayout from '../layouts/BaseLayout.astro';
import NewsletterForm from '../components/NewsletterForm.astro';
---

<BaseLayout
  title="About — Pete McPherson"
  description="[PLACEHOLDER] Read Pete McPherson's story, background, and journey. Learn what drives his work and subscribe to the weekly newsletter."
  currentPath="/about"
>
  <section class="section-padding border-b border-black/10">
    <div class="content-container">
      <p class="mb-4 font-heading text-sm uppercase tracking-[0.3em] text-accent">
        [PLACEHOLDER] About
      </p>
      <h1 class="mb-8 font-heading text-4xl uppercase tracking-wide text-black md:text-5xl lg:text-6xl">
        [PLACEHOLDER] My Story
      </h1>
      <div class="grid gap-12 md:grid-cols-[1fr_280px] md:items-start">
        <div class="space-y-6 text-base leading-relaxed text-black/70 md:text-lg">
          <p>
            [PLACEHOLDER] Opening paragraph about Pete's background — where he started, what he studied or pursued early on, and the path that led to his current work.
          </p>
          <p>
            [PLACEHOLDER] Middle paragraph covering key accomplishments, milestones, or turning points in his career. Include specific but placeholder details Pete can replace later.
          </p>
          <p>
            [PLACEHOLDER] Paragraph about current focus — what Pete is building, teaching, or exploring today. This sets context for visitors who want to learn more.
          </p>
          <p>
            [PLACEHOLDER] Closing paragraph with personal touch — values, mission, or what readers can expect from following along via the newsletter.
          </p>
        </div>
        <figure class="mx-auto w-full max-w-[280px] shrink-0">
          <img
            src="/images/about-placeholder.svg"
            alt="[PLACEHOLDER] Photo of Pete McPherson"
            width="280"
            height="350"
            class="aspect-[4/5] w-full border-2 border-black object-cover"
          />
          <figcaption class="mt-3 text-center text-sm text-black/50">
            [PLACEHOLDER] Pete McPherson
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section-padding">
    <NewsletterForm
      heading="Stay in the Loop"
      description="[PLACEHOLDER] Don't miss weekly updates from Pete. Subscribe below — it's free and you can unsubscribe anytime."
    />
  </section>
</BaseLayout>
